# Monday OAuth MCP - 環境變數配置

# ========== Monday OAuth 設置 ==========
# 訪問 https://monday.com/api 獲取這些值
MONDAY_CLIENT_ID=your_client_id_here
MONDAY_CLIENT_SECRET=your_client_secret_here
MONDAY_REDIRECT_URI=http://localhost:3001/oauth/callback

# ========== 伺服器設置 ==========
# OAuth MCP 伺服器埠
MCP_PORT=3001

# 上傳服務伺服器埠
UPLOAD_PORT=3002

# 公開伺服器 URL（用於文件下載連結）
# 本地開發：http://localhost:3002
# 遠程部署：https://your-domain.com
SERVER_URL=http://localhost:3002

# Token 存儲位置（本地開發）
TOKEN_STORAGE_PATH=./tokens.json

# 上傳目錄
UPLOAD_DIR=./uploads

# 最大文件大小（字節，預設 100MB）
MAX_FILE_SIZE=104857600

# ========== 日誌設置 ==========
# debug, info, warn, error
LOG_LEVEL=debug

# ========== 可選：雲存儲配置 ==========

# AWS S3 配置
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=your_bucket_name

# Cloudinary 配置
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# 存儲方式：local, s3, cloudinary
# STORAGE_TYPE=local
